    ORG 0
    SYM VBASE 0o10000

START:
    ; "C" - Blanco sobre Negro
    LAC C_C
    DAC VBASE
    
    ; "O" - Verde sobre Negro
    LAC C_O
    DAC 0o10001
    
    ; "M" - Cyan sobre Negro
    LAC C_M
    DAC 0o10002
    
    ; "P" - Rojo sobre Negro
    LAC C_P
    DAC 0o10003
    
    ; "U" - Magenta sobre Negro
    LAC C_U
    DAC 0o10004
    
    ; "T" - Amarillo sobre Negro
    LAC C_T
    DAC 0o10005
    
    ; "A" - Blanco sobre Azul (Atributo 0x0F)
    LAC C_A
    DAC 0o10006
    
    ; "D" - Negro sobre Blanco (Inverso)
    LAC C_D
    DAC 0o10007
    
    ; "O" - Rojo sobre Amarillo
    LAC C_O2
    DAC 0o10010
    
    ; "R" - Azul sobre Cyan
    LAC C_R
    DAC 0o10011

    ; Espacio
    LAC C_SPC
    DAC 0o10012

    ; "S" - Verde sobre Magenta
    LAC C_S
    DAC 0o10013

    ; "I" - Blanco sobre Rojo
    LAC C_I
    DAC 0o10014

    ; "C" - Amarillo sobre Azul
    LAC C_C2
    DAC 0o10015

    HLT

; --- PALETA DE COLORES (RGB) ---
; Negro: 0, Azul: 1, Verde: 2, Cyan: 3, Rojo: 4, Magenta: 5, Amarillo: 6, Blanco: 7
; Formato: [BG:3][FG:3][ASCII:8] -> Bits 13:11, 10:8, 7:0

C_C:   HEX 0x0743  ; BG:0 FG:7 (Blanco/Negro)
C_O:   HEX 0x024F  ; BG:0 FG:2 (Verde/Negro)
C_M:   HEX 0x034D  ; BG:0 FG:3 (Cyan/Negro)
C_P:   HEX 0x0450  ; BG:0 FG:4 (Rojo/Negro)
C_U:   HEX 0x0555  ; BG:0 FG:5 (Magenta/Negro)
C_T:   HEX 0x0654  ; BG:0 FG:6 (Amarillo/Negro)
C_A:   HEX 0x0F41  ; BG:1 FG:7 (Blanco/Azul)
C_D:   HEX 0x3844  ; BG:7 FG:0 (Negro/Blanco) - Bits 13:11 = 111, 10:8 = 000
C_O2:  HEX 0x344F  ; BG:6 FG:4 (Rojo/Amarillo)
C_R:   HEX 0x1952  ; BG:3 FG:1 (Azul/Cyan)
C_SPC: HEX 0x0020  ; Espacio
C_S:   HEX 0x2A53  ; BG:5 FG:2 (Verde/Magenta)
C_I:   HEX 0x2749  ; BG:4 FG:7 (Blanco/Rojo)
C_C2:  HEX 0x0E43  ; BG:1 FG:6 (Amarillo/Azul)
