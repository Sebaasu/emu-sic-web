ORG 0
	CLA
	DTA
	DTB
PALABRA1:
	LAC IA TEXTO
	DAC IA 0o10000
	INA
	ISZ TAMANO1
	JMP PALABRA1
PALABRA2:
	LAC IA TEXTO
	DAC IA 0o10115
	INA
	ISZ TAMANO2
	JMP PALABRA2
	HLT

ORG 0o100
TAMANO1: -3
TAMANO2: -3
TEXTO: 	HEX 0x0145; 'E'
	HEX 0x034D; 'M'
	HEX 0x0255; 'U'
	HEX 0x1053; 'S'
	HEX 0x3049; 'I'
	HEX 0x2043; 'C'
